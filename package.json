{
  "name": "@fozikio/cortex-engine",
  "version": "0.9.2",
  "description": "Portable cognitive engine for AI agents — storage, embeddings, memory, FSRS, and MCP server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cortex-engine": "dist/bin/serve.js",
    "fozikio": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "serve": "node dist/bin/serve.js",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fozikio/reflex": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "better-sqlite3": "^11.7.0",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google-cloud/aiplatform": "^3.12.0",
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/vertexai": "^1.9.0",
    "@huggingface/transformers": "^3.8.1",
    "firebase-admin": "^13.0.0",
    "openai": "^4.77.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google-cloud/aiplatform": {
      "optional": true
    },
    "@google-cloud/firestore": {
      "optional": true
    },
    "@google-cloud/vertexai": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google-cloud/aiplatform": "^3.12.0",
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/vertexai": "^1.9.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "firebase-admin": "^13.0.0",
    "openai": "^4.77.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "cortex",
    "cognitive",
    "memory",
    "fsrs",
    "mcp",
    "ai-agent",
    "embeddings",
    "fozikio",
    "persistent-memory",
    "knowledge-graph",
    "spaced-repetition"
  ],
  "license": "MIT",
  "author": "Fozikio <hello@fozikio.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fozikio/cortex-engine.git"
  },
  "homepage": "https://github.com/Fozikio/cortex-engine/wiki",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/idapixl"
  },
  "files": [
    "dist",
    "public",
    "hooks",
    "skills",
    "reflex-rules",
    "fozikio.json",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./stores/firestore": {
      "import": "./dist/stores/firestore.js",
      "types": "./dist/stores/firestore.d.ts"
    },
    "./stores/sqlite": {
      "import": "./dist/stores/sqlite.js",
      "types": "./dist/stores/sqlite.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    },
    "./rest": {
      "import": "./dist/rest/server.js",
      "types": "./dist/rest/server.d.ts"
    }
  }
}
